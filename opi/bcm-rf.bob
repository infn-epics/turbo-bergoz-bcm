    <widget type="action_button" version="2.0.0">
      <text>Save to EEPROM</text>
      <pv_name>$(P):SAVE_CFG_CMD</pv_name>
      <x>530</x>
      <y>30</y>
      <width>150</width>
      <height>55</height>
      <actions>
        <action type="write_pv">
          <pv_name>$(P):SAVE_CFG_CMD</pv_name>
          <value>1</value>
        </action>
      </actions>
      <foreground_color>
        <color red="255" green="0" blue="0" />
      </foreground_color>
    </widget>
  </widget>

