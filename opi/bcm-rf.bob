    <name>ConnLED</name>
    <pv_name>$(P):CONNECTED</pv_name>
    <x>670</x>
    <y>8</y>
    <width>24</width>
    <height>24</height>
  </widget>
  <widget type="group" version="3.0.0">
    <name>Measurement</name>
    <x>10</x>
    <y>45</y>
    <width>700</width>
    <height>170</height>
    <style>1</style>
    <widget type="label" version="2.0.0">
      <name>MeasTitle</name>
