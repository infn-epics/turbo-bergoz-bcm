      <pv_name>$(P):VOLTAGE_RB</pv_name>
      <x>155</x>
      <y>30</y>
      <width>180</width>
      <height>25</height>
      <precision>6</precision>
    </widget>
    <widget type="label" version="2.0.0">
      <text>V</text>
      <x>340</x>
      <y>30</y>
      <width>30</width>
      <height>25</height>
    </widget>
