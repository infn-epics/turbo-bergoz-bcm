    <widget type="combo" version="2.0.0">
      <pv_name>$(P):REV_FUNC_SP</pv_name>
      <x>115</x>
      <y>60</y>
      <width>100</width>
      <height>25</height>
    </widget>
    <widget type="textupdate" version="2.0.0">
      <pv_name>$(P):REV_FUNC_RB</pv_name>
      <x>220</x>
      <y>60</y>
      <width>80</width>
      <height>25</height>
